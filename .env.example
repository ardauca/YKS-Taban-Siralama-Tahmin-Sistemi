# Ortam değişkenleri şablonu — gerçek değerleri .env dosyasına koy (.gitignore'da)
# Kullanım: cp .env.example .env && dosyayı düzenle

# ── Veritabanı ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=yks_tahmin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# ── Opsiyonel API anahtarları ────────────────────────────────────────────────
# GOOGLE_TRENDS_API_KEY=
# OPENAI_API_KEY=

# ── Scraper ayarları ─────────────────────────────────────────────────────────
SCRAPER_RATE_LIMIT_SECONDS=1.5
SCRAPER_MAX_RETRIES=3
